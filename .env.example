# Resend — onboarding + quote email delivery
RESEND_API_KEY=
QUOTE_TO_EMAIL=
QUOTE_FROM_EMAIL=onboarding@resend.dev

# Cloudflare Turnstile — form anti-bot
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Make.com — onboarding intake webhook
# POST'd a fully-shaped SiteContent JSON after each onboarding submission.
# Configure your Make scenario to receive this and forward to email / Airtable / GitHub.
MAKE_WEBHOOK_URL=

# Vercel Blob — image uploads (onboarding form)
BLOB_READ_WRITE_TOKEN=

# Twilio — SMS / account API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Stripe — Checkout + webhooks
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ONBOARDING=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# Base URL used in Stripe Checkout success/cancel redirects.
# Local: http://localhost:3000  ·  Production: https://juneaudigitaldesigns.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel KV (Upstash Redis) — stores signed MSA agreement records
# Provision via Vercel Dashboard → Storage → Create → Upstash Redis
# After provisioning, run `vercel env pull .env.local` to populate locally
KV_REST_API_URL=
KV_REST_API_TOKEN=
